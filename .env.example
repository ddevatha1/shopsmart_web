# Kroger Developer Portal OAuth2 client credentials (client_credentials
# grant — used server-side only, never exposed to the browser).
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# The scraper-service deployment (see scraper-service/) that owns the
# Trader Joe's session cookie and the Sprouts product-image fallback —
# both need a real headless browser, which can't run in a Vercel
# serverless function. Point this at your deployed Render URL (or a local
# scraper-service instance for local dev).
SCRAPER_SERVICE_URL=
# Shared secret — must match SCRAPER_SERVICE_TOKEN set on the
# scraper-service deployment itself.
SCRAPER_SERVICE_TOKEN=
